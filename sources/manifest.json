{
  "name": "__MSG_extName__",
  "short_name": "__MSG_extShortName__",
  "description": "__MSG_extDescription__",
  "version": "1.2",
  "version_name": "1.2.0",
  "manifest_version": 3,
  "author": "Peter Macko (Konica Minolta IT Solutions Czech)",
  "homepage_url": "https://www.konicaminoltaits.cz",
  "minimum_chrome_version": "114",
  "default_locale": "en",
  "icons": {
    "16": "icons/pluxee-152.png",
    "32": "icons/pluxee-152.png",
    "48": "icons/pluxee-152.png",
    "128": "icons/pluxee-152.png"
  },
  "host_permissions": [
    "https://pluxee.datadoghq.eu/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://pluxee.datadoghq.eu/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}